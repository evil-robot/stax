{
  "name": "@artistsandrobots/stax",
  "version": "0.1.0",
  "description": "Generate isometric 3D stacked-cube bar charts in Node.js. Returns a PNG Buffer. No browser, no Puppeteer, no headless Chrome. Works in Next.js, Express, Lambda, Railway, and anywhere Node runs.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && cp -r src/vendor dist/vendor",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "isometric",
    "isometric-chart",
    "3d-chart",
    "bar-chart",
    "stacked-chart",
    "chart",
    "node",
    "nodejs",
    "canvas",
    "node-canvas",
    "png",
    "image-generation",
    "visualization",
    "server-side",
    "server-side-rendering",
    "obelisk",
    "nextjs",
    "lambda",
    "artists-and-robots"
  ],
  "author": "Jason Alan Snyder <jas@evilrobot.com> (https://evilrobot.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/evil-robot/stax.git"
  },
  "homepage": "https://github.com/evil-robot/stax#readme",
  "bugs": {
    "url": "https://github.com/evil-robot/stax/issues"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "canvas": "^3.2.3",
    "jsdom": "^29.1.1"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
